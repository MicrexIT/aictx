{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "aictx-demo",
  "compatibility_date": "2026-05-05",
  "assets": {
    "directory": "./site/dist",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  },
  "routes": [
    {
      "pattern": "memory.aictx.dev",
      "custom_domain": true
    }
  ]
}
