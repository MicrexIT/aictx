---
interface Props {
  title: string;
  description: string;
  href: string;
  publishedAt: Date;
  tags?: string[];
}

const { title, description, href, publishedAt, tags = [] } = Astro.props;
const dateLabel = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric"
}).format(publishedAt);
---

<article class="post-card">
  <a href={href}>
    <time datetime={publishedAt.toISOString()}>{dateLabel}</time>
    <h2>{title}</h2>
    <p>{description}</p>
    {
      tags.length > 0 && (
        <div class="post-tags" aria-label="Post tags">
          {tags.map((tag) => (
            <span>{tag}</span>
          ))}
        </div>
      )
    }
  </a>
</article>
