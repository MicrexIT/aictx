---
import GitHubIcon from "../components/GitHubIcon.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Memory - Local memory for AI coding tools",
  description = "Memory gives AI coding tools local, reviewable project memory so every session stops starting from scratch."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <script src="/stars.js" defer></script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Memory home">
        <img class="brand-mark" src="/favicon.ico" width="34" height="34" alt="" aria-hidden="true" />
        <span>Memory</span>
      </a>

      <nav aria-label="Primary navigation">
        <a href="/#demo">Demo Viewer</a>
        <a href="https://docs.aictx.dev" rel="noreferrer">Docs</a>
        <a href="/use-cases/">Use Cases</a>
      </nav>

      <details class="mobile-menu">
        <summary aria-label="Open navigation menu">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <div class="mobile-menu-panel">
          <a href="/#demo">Demo Viewer</a>
          <a href="https://docs.aictx.dev" rel="noreferrer">Docs</a>
          <a href="/use-cases/">Use Cases</a>
          <a href="https://github.com/aictx/memory" rel="noreferrer">GitHub</a>
        </div>
      </details>

      <a class="github-pill" href="https://github.com/aictx/memory" rel="noreferrer">
        <GitHubIcon />
        <span>GitHub</span>
        <strong data-star-count="compact"></strong>
      </a>
    </header>

    <slot />

    <footer class="site-footer">
      <div>
        <strong>Memory</strong>
        <p>Local, reviewable project memory for AI coding tools.</p>
      </div>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="https://docs.aictx.dev" rel="noreferrer">Docs</a>
        <a href="/#demo">Demo Viewer</a>
        <a href="/use-cases/">Use Cases</a>
        <a href="https://github.com/aictx/memory" rel="noreferrer">GitHub</a>
        <a href="mailto:michele@remics.tech">Contact us</a>
      </nav>
    </footer>
  </body>
</html>
