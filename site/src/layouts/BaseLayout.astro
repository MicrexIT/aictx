---
import GitHubIcon from "../components/GitHubIcon.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Aictx - Local memory for AI coding tools",
  description = "Aictx gives AI coding tools local, reviewable project memory so every session stops starting from scratch."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script src="/stars.js" defer></script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Aictx home">
        <span class="brand-mark" aria-hidden="true">A</span>
        <span>Aictx</span>
      </a>

      <nav aria-label="Primary navigation">
        <a href="/#context">Context</a>
        <a href="/#workflow">How it works</a>
        <a href="/#demo">Demo</a>
        <a href="/use-cases/">Use cases</a>
        <a href="https://docs.aictx.dev" rel="noreferrer">Docs</a>
      </nav>

      <details class="mobile-menu">
        <summary aria-label="Open navigation menu">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <div class="mobile-menu-panel">
          <a href="/#context">Context</a>
          <a href="/#workflow">How it works</a>
          <a href="/#demo">Demo</a>
          <a href="/use-cases/">Use cases</a>
          <a href="https://docs.aictx.dev" rel="noreferrer">Docs</a>
          <a href="https://github.com/MicrexIT/aictx" rel="noreferrer">GitHub</a>
        </div>
      </details>

      <a class="github-pill" href="https://github.com/MicrexIT/aictx" rel="noreferrer">
        <GitHubIcon />
        <span>GitHub</span>
        <strong data-star-count="compact"></strong>
      </a>
    </header>

    <slot />

    <footer class="site-footer">
      <div>
        <strong>Aictx</strong>
        <p>Local, reviewable project memory for AI coding tools.</p>
      </div>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="https://docs.aictx.dev" rel="noreferrer">Docs</a>
        <a href="https://demo.aictx.dev/?token=demo" rel="noreferrer">Demo</a>
        <a href="/use-cases/">Use cases</a>
        <a href="https://github.com/MicrexIT/aictx" rel="noreferrer">GitHub</a>
      </nav>
    </footer>
  </body>
</html>
