---
import GitHubIcon from "../components/GitHubIcon.astro";
import { buildStructuredData, siteName, socialImageUrl } from "../seo";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Memory by Aictx - local-first project memory for AI coding agents",
  description = "Memory by Aictx gives AI coding agents local, reviewable project memory so every session stops starting from scratch."
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://memory.aictx.dev");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const socialImage = socialImageUrl(siteUrl);
const websiteJsonLd = buildStructuredData(siteUrl);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content="Memory by Aictx project memory overview" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content="Memory by Aictx project memory overview" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)}></script>
    <script src="/stars.js" defer></script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Memory home">
        <img class="brand-mark" src="/favicon.ico" width="34" height="34" alt="" aria-hidden="true" />
        <span>Memory</span>
      </a>

      <nav aria-label="Primary navigation">
        <a href="/#demo">Demo Viewer</a>
        <a href="https://docs.aictx.dev" rel="noreferrer">Docs</a>
        <a href="/use-cases/">Use Cases</a>
      </nav>

      <details class="mobile-menu">
        <summary aria-label="Open navigation menu">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <div class="mobile-menu-panel">
          <a href="/#demo">Demo Viewer</a>
          <a href="https://docs.aictx.dev" rel="noreferrer">Docs</a>
          <a href="/use-cases/">Use Cases</a>
          <a href="https://github.com/aictx/memory" rel="noreferrer">GitHub</a>
        </div>
      </details>

      <a class="github-pill" href="https://github.com/aictx/memory" rel="noreferrer">
        <GitHubIcon />
        <span>GitHub</span>
        <strong data-star-count="compact"></strong>
      </a>
    </header>

    <slot />

    <footer class="site-footer">
      <div>
        <strong>Memory by Aictx</strong>
        <p>Local, reviewable project memory for AI coding tools.</p>
      </div>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="https://docs.aictx.dev" rel="noreferrer">Docs</a>
        <a href="/#demo">Demo Viewer</a>
        <a href="/use-cases/">Use Cases</a>
        <a href="https://github.com/aictx/memory" rel="noreferrer">GitHub</a>
        <a href="mailto:michele@remics.tech">Contact us</a>
      </nav>
    </footer>
  </body>
</html>
