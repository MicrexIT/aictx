---
import { getCollection } from "astro:content";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort(
  (left, right) => right.data.publishedAt.getTime() - left.data.publishedAt.getTime()
);
---

<BaseLayout
  title="Memory Use Cases - Memory by Aictx"
  description="Practical use cases for Memory by Aictx and durable project memory for AI coding agents."
>
  <main>
    <section class="blog-hero use-cases-hero" aria-labelledby="use-cases-title">
      <div class="use-cases-hero-panel">
        <p class="section-kicker">Use cases</p>
        <h1 id="use-cases-title">Where durable context helps AI coding agents.</h1>
        <p>
          Practical notes on keeping product intent, repo conventions, and sharp edges available
          across agent sessions.
        </p>
      </div>
    </section>

    <section class="blog-list-section" aria-label="Use case articles">
      {
        posts.length > 0 ? (
          <div class="blog-list">
            {posts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                href={`/blog/${post.id}/`}
                publishedAt={post.data.publishedAt}
                tags={post.data.tags}
              />
            ))}
          </div>
        ) : (
          <div class="empty-state">
            <h2>No use cases published yet.</h2>
            <p>Markdown posts added under <code>site/src/content/blog</code> will appear here newest first.</p>
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>
