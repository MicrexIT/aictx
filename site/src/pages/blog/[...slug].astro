---
import { getCollection, render } from "astro:content";
import Prose from "../../components/Prose.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { socialImageUrl } from "../../seo";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const siteUrl = Astro.site ?? new URL("https://memory.aictx.dev");
const canonicalUrl = new URL(`/blog/${post.id}/`, siteUrl).toString();
const socialImage = socialImageUrl(siteUrl);
const publishedLabel = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric",
}).format(post.data.publishedAt);
const blogPostingJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishedAt.toISOString(),
  dateModified: (post.data.updatedAt ?? post.data.publishedAt).toISOString(),
  image: socialImage,
  keywords: post.data.tags ?? [],
  mainEntityOfPage: canonicalUrl,
  author: {
    "@type": "Organization",
    name: "Aictx"
  },
  publisher: {
    "@type": "Organization",
    name: "Aictx",
    logo: {
      "@type": "ImageObject",
      url: new URL("/assets/logo/memory-constellation-logo.svg", siteUrl).toString()
    }
  }
};
---

<BaseLayout
  title={`${post.data.title} - Memory by Aictx`}
  description={post.data.description}
  ogType="article"
  structuredData={blogPostingJsonLd}
>
  <main>
    <article class="post-shell">
      <a class="back-link" href="/blog/">Back</a>

      <header class="post-header">
        <time datetime={post.data.publishedAt.toISOString()}
          >{publishedLabel}</time
        >
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
        {
          post.data.tags && post.data.tags.length > 0 && (
            <div class="post-tags" aria-label="Post tags">
              {post.data.tags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>
          )
        }
      </header>

      <div class="post-body">
        <Prose>
          <Content />
        </Prose>
      </div>
    </article>
  </main>
</BaseLayout>
