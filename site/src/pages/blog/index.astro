---
import { getCollection } from "astro:content";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort(
  (left, right) =>
    right.data.publishedAt.getTime() - left.data.publishedAt.getTime(),
);
---

<BaseLayout
  title="Aictx Blog - Local memory for AI coding agents"
  description="Updates, product thinking, and implementation notes from Aictx."
>
  <main>
    <section class="blog-hero" aria-labelledby="blog-title">
      <p class="section-kicker">Use Cases</p>
      <h1 id="blog-title">Notes on durable context for AI coding agents.</h1>
      <p>
        Product updates, implementation notes, and field observations from
        building local-first project memory.
      </p>
    </section>

    <section class="blog-list-section" aria-label="Blog posts">
      {
        posts.length > 0 ? (
          <div class="blog-list">
            {posts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                href={`/blog/${post.id}/`}
                publishedAt={post.data.publishedAt}
                tags={post.data.tags}
              />
            ))}
          </div>
        ) : (
          <div class="empty-state">
            <h2>No posts published yet.</h2>
            <p>
              Markdown posts added under <code>site/src/content/blog</code> will
              appear here newest first.
            </p>
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>
