---
import BaseLayout from "../layouts/BaseLayout.astro";
import { keywordLandingPages, keywordPagePath, type KeywordLandingPage } from "../seo-pages";

export function getStaticPaths() {
  return keywordLandingPages.map((page) => ({
    params: { slug: page.slug },
    props: { page }
  }));
}

const { page } = Astro.props as { page: KeywordLandingPage };
const siteUrl = Astro.site ?? new URL("https://memory.aictx.dev");
const pageUrl = new URL(keywordPagePath(page), siteUrl).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: page.h1,
  headline: page.h1,
  description: page.description,
  url: pageUrl,
  about: page.keywords,
  isPartOf: {
    "@type": "WebSite",
    name: "Memory by Aictx",
    url: new URL("/", siteUrl).toString()
  },
  mainEntity: {
    "@type": "SoftwareApplication",
    name: "Memory by Aictx",
    alternateName: ["Memory", "@aictx/memory", "memory", "memory-mcp"],
    applicationCategory: "DeveloperApplication",
    operatingSystem: "macOS, Linux, Windows",
    codeRepository: "https://github.com/aictx/memory",
    downloadUrl: "https://www.npmjs.com/package/@aictx/memory"
  }
};
---

<BaseLayout title={page.title} description={page.description} structuredData={structuredData}>
  <main>
    <section class="blog-hero use-cases-hero" aria-labelledby="keyword-page-title">
      <div class="use-cases-hero-panel">
        <p class="section-kicker">{page.kicker}</p>
        <h1 id="keyword-page-title">{page.h1}</h1>
        <p>{page.lead}</p>
        <div class="hero-actions keyword-actions">
          <a class="button primary" href={page.primaryCta.href} rel="noreferrer">{page.primaryCta.label}</a>
          {
            page.secondaryCta && (
              <a class="button secondary" href={page.secondaryCta.href} rel="noreferrer">{page.secondaryCta.label}</a>
            )
          }
        </div>
      </div>
    </section>

    <section class="value-section" aria-labelledby="keyword-benefits-title">
      <div class="value-section-inner">
        <div class="section-heading">
          <h2 id="keyword-benefits-title">What this solves.</h2>
        </div>

        <div class="comparison comparison-why">
          {
            page.sections.map((section) => (
              <div>
                <span>{section.eyebrow}</span>
                <strong>{section.title}</strong>
                <p>{section.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="blog-list-section" aria-labelledby="related-pages-title">
      <div class="section-heading">
        <h2 id="related-pages-title">Related Memory guides.</h2>
        <p>
          Continue with adjacent project-memory workflows for AI coding agents,
          AI coding assistants, and MCP-capable tools.
        </p>
      </div>

      <div class="post-tags keyword-tags" aria-label="Related pages">
        {
          page.related.map((link) => (
            <a href={link.href} rel={link.href.startsWith("http") ? "noreferrer" : undefined}>{link.label}</a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
