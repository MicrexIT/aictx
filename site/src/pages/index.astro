---
import GitHubIcon from "../components/GitHubIcon.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const demoUrl = "https://demo.aictx.dev/?token=demo";
---

<BaseLayout>
  <main id="top">
    <section class="hero">
      <div class="hero-panel">
        <a class="eyebrow-link" href="https://github.com/MicrexIT/aictx" rel="noreferrer">
          <GitHubIcon />
          Local-first and open source <span data-star-count></span>
        </a>
        <h1>Stop re-explaining your<br />repo to AI agents.</h1>
        <p class="hero-copy">
          Aictx gives agents durable project memory they can load before work and update after,
          stored as local files you can review with Git.
        </p>
        <p class="hero-note">
          Not a chat transcript archive or always-on capture server. Aictx saves durable
          project knowledge as reviewable repo memory.
        </p>

        <div class="hero-actions">
          <a class="button primary" href="https://github.com/MicrexIT/aictx" rel="noreferrer">Install Aictx</a>
          <a class="button secondary" href={demoUrl} rel="noreferrer">
            Browse demo
          </a>
        </div>

        <div class="hero-command" aria-label="Quick start commands">
          <code>npm install -g @aictx/memory</code>
        </div>
      </div>
    </section>

    <section class="split-section" id="context" aria-labelledby="context-title">
      <div class="section-heading">
        <h2 id="context-title">Durable memory beats bigger prompts.</h2>
        <p>
          AGENTS.md and CLAUDE.md files can help, but loading them on every task adds noise.
          Aictx stores project knowledge once, then loads the relevant pieces for the work in
          front of the agent.
        </p>
      </div>

      <div class="comparison">
        <div>
          <strong>Fewer repeated explanations</strong>
          <p>Keep product intent, conventions, and sharp edges available across sessions.</p>
        </div>
        <div>
          <strong>Not capture-everything memory</strong>
          <p>Keep decisions, constraints, workflows, and gotchas future agents should trust.</p>
        </div>
        <div>
          <strong>Reviewable memory</strong>
          <p>Store memory as local files that fit normal Git review and rollback.</p>
        </div>
      </div>
    </section>

    <section class="impact-section" id="before-after" aria-labelledby="before-after-title">
      <div class="section-heading">
        <h2 id="before-after-title">Project memory for Codex.</h2>
        <p>
          Load context before work. Inspect agent memory. Review changes like code.
        </p>
      </div>

      <div class="impact-module">
        <div class="impact-copy">
          <div class="impact-tabs" role="tablist" aria-label="Before and after use cases">
            <button type="button" role="tab" aria-selected="true" aria-controls="impact-token" data-impact-tab="impact-token">
              <span>01</span>
              Context
            </button>
            <button type="button" role="tab" aria-selected="false" aria-controls="impact-explain" data-impact-tab="impact-explain">
              <span>02</span>
              Viewer
            </button>
            <button type="button" role="tab" aria-selected="false" aria-controls="impact-handoffs" data-impact-tab="impact-handoffs">
              <span>03</span>
              Review
            </button>
          </div>

          <div class="impact-panel-copy is-active" data-impact-copy="impact-token">
            <span class="section-kicker">Start with context</span>
            <h3>Codex starts with the missing context.</h3>
            <p>
              Aictx loads the decisions, gotchas, and workflows Codex would otherwise spend the
              first minutes rediscovering.
            </p>
          </div>

          <div class="impact-panel-copy" data-impact-copy="impact-explain" hidden>
            <span class="section-kicker">See what agents know</span>
            <h3>Inspect the memory agents will use.</h3>
            <p>
              Keep AGENTS.md for operating rules. Use the viewer for searchable decisions, sources,
              workflows, and gotchas.
            </p>
          </div>

          <div class="impact-panel-copy" data-impact-copy="impact-handoffs" hidden>
            <span class="section-kicker">Review like code</span>
            <h3>Let agents learn under review.</h3>
            <p>
              Aictx writes local memory files, so new agent knowledge can be diffed, committed,
              or rolled back.
            </p>
          </div>
        </div>

        <div class="impact-visual">
          <div class="impact-visual-panel is-active" id="impact-token" role="tabpanel" data-impact-panel="impact-token" style="--reveal: 48%">
            <div class="comparison-labels" aria-hidden="true">
              <span>Before</span>
              <span>After</span>
            </div>
            <div class="comparison-state" aria-hidden="true">Compare</div>
            <div class="scene-layer before">
              <div class="codex-chat codex-chat-before" aria-label="Codex chat without Aictx">
                <div class="codex-chat-topbar">
                  <span>Update viewer search behavior</span>
                  <strong>•••</strong>
                </div>
                <div class="codex-user-bubble">
                  <p>Can you polish viewer search?</p>
                </div>
                <div class="codex-work-pill">Worked for 7m 18s⌄</div>
                <div class="codex-divider"></div>
                <div class="codex-response">
                  <p>I need to inspect the docs and viewer code to recover the product direction.</p>
                </div>
                <div class="codex-command-row">
                  <span aria-hidden="true">›</span>
                  Ran <code>rg "viewer|search|handbook|dashboard"</code>
                </div>
                <div class="codex-command-row">
                  <span aria-hidden="true">›</span>
                  Read <code>docs/viewer.md</code>, <code>viewer/src/App.svelte</code>
                </div>
                <div class="codex-command-row muted-row">
                  <span aria-hidden="true">›</span>
                  Explored 11 files, 4 searches
                </div>
                <div class="codex-response warning-message">
                  <p>Remind me: are we still avoiding dashboard-style UI here?</p>
                </div>
              </div>
            </div>
            <div class="scene-layer after">
              <div class="codex-chat codex-chat-after" aria-label="Codex chat with Aictx">
                <div class="codex-chat-topbar">
                  <span>Update viewer search behavior</span>
                  <strong>•••</strong>
                </div>
                <div class="codex-user-bubble">
                  <p>Can you polish viewer search?</p>
                </div>
                <div class="codex-command-row aictx-command-row">
                  <span aria-hidden="true">›</span>
                  Ran <code>aictx load "improve viewer search UI"</code>
                </div>
                <div class="aictx-context-pack">
                  <span>AI Context Pack</span>
                  <strong>Viewer memory page follows a document-style handbook layout.</strong>
                  <p>Keep accents neutral. Avoid dashboard-style controls. Verify with viewer tests.</p>
                </div>
                <div class="codex-command-row muted-row">
                  <span aria-hidden="true">›</span>
                  Loaded 6 relevant memories before editing
                </div>
                <div class="codex-response ready-message">
                  <p>I have the UI constraint and verification path. I’ll update search without reopening old decisions.</p>
                </div>
              </div>
            </div>
            <span class="reveal-divider" aria-hidden="true"></span>
            <span class="reveal-handle" aria-hidden="true"></span>
            <input
              class="reveal-scrubber"
              type="range"
              min="0"
              max="100"
              value="48"
                aria-label="Slide between before and after for repeated explanations"
            />
          </div>

          <div class="impact-visual-panel" id="impact-explain" role="tabpanel" data-impact-panel="impact-explain" style="--reveal: 48%" hidden>
            <div class="comparison-labels" aria-hidden="true">
              <span>Before</span>
              <span>After</span>
            </div>
            <div class="comparison-state" aria-hidden="true">Compare</div>
            <div class="scene-layer before">
              <div class="agents-file" aria-label="Overloaded AGENTS.md file">
                <div class="file-title">
                  <span>AGENTS.md</span>
                  <strong>only source of context</strong>
                </div>
                <div class="markdown-line heading">## Agent Instructions</div>
                <div class="markdown-line">- Use pnpm for package workflows.</div>
                <div class="markdown-line">- Load memory before non-trivial work.</div>
                <div class="markdown-line heading">## Product Decisions</div>
                <div class="markdown-line overloaded">- Viewer should feel like a document handbook, not a dashboard.</div>
                <div class="markdown-line overloaded">- Do not show relation graphs by default.</div>
                <div class="markdown-line heading">## Gotchas</div>
                <div class="markdown-line">- CI tests need built viewer artifacts.</div>
                <div class="file-search">Search “viewer decision” → 17 matches</div>
              </div>
            </div>
            <div class="scene-layer after">
              <div class="viewer-snapshot" aria-label="Aictx viewer demo">
                <span class="browser-bar">
                  <i></i>
                  <i></i>
                  <i></i>
                  <code>demo.aictx.dev</code>
                </span>
                <img
                  src="/assets/viewer-demo.png"
                  alt="Aictx viewer showing searchable project memory and memory rows."
                />
                <div class="viewer-callout">
                  Searchable decisions, workflows, gotchas, and sources
                </div>
              </div>
            </div>
            <span class="reveal-divider" aria-hidden="true"></span>
            <span class="reveal-handle" aria-hidden="true"></span>
            <input
              class="reveal-scrubber"
              type="range"
              min="0"
              max="100"
              value="48"
                aria-label="Slide between before and after for re-explaining"
            />
          </div>

          <div class="impact-visual-panel" id="impact-handoffs" role="tabpanel" data-impact-panel="impact-handoffs" style="--reveal: 50%" hidden>
            <div class="comparison-labels" aria-hidden="true">
              <span>Before</span>
              <span>After</span>
            </div>
            <div class="comparison-state" aria-hidden="true">Compare</div>
            <div class="scene-layer before">
              <div class="lost-chat-memory" aria-label="Useful memory buried in chat history">
                <div class="lost-chat-title">Previous chats</div>
                <div class="lost-chat-line">“CI needs built viewer artifacts before tests.”</div>
                <div class="lost-chat-line">“Keep viewer UI document-like, not dashboard-like.”</div>
                <div class="lost-chat-line">“Use pnpm 10.11.0 for package workflows.”</div>
                <div class="lost-chat-line faded">“Relation rows beat tiny node diagrams.”</div>
                <div class="lost-chat-footer">Useful knowledge. No durable review.</div>
              </div>
            </div>
            <div class="scene-layer after">
              <div class="memory-diff" aria-label="Aictx memory diff">
                <div class="diff-title">
                  <span>aictx diff</span>
                  <strong>2 memory files</strong>
                </div>
                <div class="diff-file">.aictx/memory/decisions/viewer-handbook-layout.md</div>
                <div class="diff-line added">+ Viewer pages should read like a document-style handbook.</div>
                <div class="diff-line added">+ Avoid dashboard-style relation graphs.</div>
                <div class="diff-file">.aictx/memory/workflows/post-task-verification.md</div>
                <div class="diff-line added">+ Verify with pnpm run typecheck and focused viewer tests.</div>
                <div class="diff-footer">Review, commit, or roll back.</div>
              </div>
            </div>
            <span class="reveal-divider" aria-hidden="true"></span>
            <span class="reveal-handle" aria-hidden="true"></span>
            <input
              class="reveal-scrubber"
              type="range"
              min="0"
              max="100"
              value="50"
                aria-label="Slide between before and after for handoffs"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="workflow" id="workflow" aria-labelledby="workflow-title">
      <div class="section-heading">
        <h2 id="workflow-title">Load context. Save memory. Review the diff.</h2>
        <p>
          Aictx stores memory as readable local files beside your repo, so changes stay visible
          and reviewable.
        </p>
      </div>

      <div class="steps">
        <article>
          <span>01</span>
          <h3>Load before work</h3>
          <code>aictx load "change auth routes"</code>
          <p>Agents start with the project knowledge that matters for the task.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Save durable knowledge</h3>
          <code>aictx save --stdin</code>
          <p>Agents save decisions, gotchas, workflows, and handoffs as they work.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Review like code</h3>
          <code>aictx diff</code>
          <p>Inspect memory changes before they guide future agents.</p>
        </article>
      </div>
    </section>

    <section class="demo-section" id="demo" aria-labelledby="demo-title">
      <div class="section-heading">
        <h2 id="demo-title">See the memory future agents will use.</h2>
      </div>

      <div class="demo-art">
        <a class="viewer-frame" href={demoUrl} rel="noreferrer">
          <span class="browser-bar">
            <i></i>
            <i></i>
            <i></i>
            <code>demo.aictx.dev</code>
          </span>
          <img
            src="/assets/viewer-demo.png"
            alt="Aictx viewer showing the coding handbook, memory library filters, and expandable project memory rows."
          />
        </a>
      </div>

      <div class="demo-footer">
        <p>Inspect the local project memory your agents load before work.</p>
        <a class="text-link" href={demoUrl} rel="noreferrer">
          Open live demo
        </a>
      </div>
    </section>
  </main>

  <script>
    const revealControls = document.querySelectorAll(".reveal-scrubber");
    const impactTabs = document.querySelectorAll("[data-impact-tab]");
    const impactPanels = document.querySelectorAll("[data-impact-panel]");
    const impactCopy = document.querySelectorAll("[data-impact-copy]");

    for (const control of revealControls) {
      const panel = control.closest("[data-impact-panel]");
      const setReveal = () => {
        panel?.style.setProperty("--reveal", `${control.value}%`);
        const state = panel?.querySelector(".comparison-state");
        if (state) {
          state.textContent =
            control.value === "0" ? "Showing after" : control.value === "100" ? "Showing before" : "Compare";
        }
      };

      control.addEventListener("input", setReveal);
      if (control.closest("[data-impact-panel]")?.classList.contains("is-active")) {
        setReveal();
      }
    }

    for (const tab of impactTabs) {
      tab.addEventListener("click", () => {
        const target = tab.getAttribute("data-impact-tab");

        for (const item of impactTabs) {
          item.setAttribute("aria-selected", String(item === tab));
        }

        for (const panel of impactPanels) {
          const isActive = panel.getAttribute("data-impact-panel") === target;
          panel.hidden = !isActive;
          panel.classList.toggle("is-active", isActive);

          if (isActive) {
            const scrubber = panel.querySelector(".reveal-scrubber");
            panel.style.setProperty("--reveal", `${scrubber?.value ?? 50}%`);
            const state = panel.querySelector(".comparison-state");
            if (state) {
              state.textContent =
                scrubber?.value === "0"
                  ? "Showing after"
                  : scrubber?.value === "100"
                    ? "Showing before"
                    : "Compare";
            }
          }
        }

        for (const copy of impactCopy) {
          const isActive = copy.getAttribute("data-impact-copy") === target;
          copy.hidden = !isActive;
          copy.classList.toggle("is-active", isActive);
        }
      });
    }
  </script>
</BaseLayout>
