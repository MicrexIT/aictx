{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "memory-demo",
  "main": "src/viewer/demo-worker.ts",
  "compatibility_date": "2026-05-05",
  "assets": {
    "directory": "./dist/viewer",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  },
  "routes": [
    {
      "pattern": "demo.aictx.dev",
      "custom_domain": true
    }
  ]
}
