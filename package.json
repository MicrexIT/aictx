{
  "name": "@aictx/memory",
  "version": "0.1.21",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "aictx": "dist/cli/main.js",
    "aictx-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist",
    "docs",
    "integrations",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm build:guidance && pnpm build:version && pnpm build:code && pnpm build:schemas && pnpm build:viewer",
    "build:code": "tsup",
    "build:docs": "astro build --root docs",
    "build:schemas": "node scripts/copy-schemas.mjs",
    "build:site": "astro build --root site",
    "build:version": "node scripts/generate-version.mjs",
    "build:viewer": "vite build --config viewer/vite.config.ts",
    "build:guidance": "node scripts/generate-agent-guidance.mjs",
    "dev": "tsx src/cli/main.ts",
    "dev:docs": "astro dev --root docs",
    "dev:mcp": "tsx src/mcp/server.ts",
    "dev:site": "astro dev --root site",
    "version:patch": "npm version patch --no-git-tag-version && node scripts/sync-readme-install-version.mjs && node scripts/generate-version.mjs",
    "test": "vitest run",
    "test:local": "pnpm typecheck && pnpm test:package",
    "test:package": "vitest run test/integration/release/packaging.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig viewer/tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "ajv": "^8.20.0",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aictx/memory": "^0.1.10",
    "@astrojs/starlight": "^0.38.4",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "astro": "^6.2.2",
    "playwright": "^1.59.1",
    "starlight-llms-txt": "^0.8.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^6.3.7",
    "vitest": "^4.1.5"
  }
}
